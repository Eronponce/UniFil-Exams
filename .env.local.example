# Copy this file to .env.local and fill in values

# AI Providers (optional — only needed when using that provider)
CLAUDE_API_KEY=
GEMINI_API_KEY=

# Ollama (local Qwen) — defaults if not set
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:latest

# App
NEXT_PUBLIC_APP_NAME=UniFil Exams

# GitHub issue chat (optional)
# If GITHUB_ISSUES_REPO is empty, the app tries to infer owner/repo from git origin.
GITHUB_ISSUES_REPO=
GITHUB_ISSUES_LABELS=
